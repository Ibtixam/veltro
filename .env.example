# ══════════════════════════════════════════════════════════════════
# VELTRO — Production Environment Variables
# Copy to .env and fill ALL values before deployment
# Never commit .env to git
# ══════════════════════════════════════════════════════════════════

# ── APP ──────────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://veltro.io
APP_PORT=3000
API_PORT=4000
JWT_SECRET=minimum_64_chars_random_string_required_here_generate_with_openssl
JWT_EXPIRY=7d
ENCRYPTION_KEY=32_byte_hex_key_for_encrypting_api_credentials_at_rest

# ── DATABASE (PgBouncer transaction mode — Bible V2) ─────────────────
DATABASE_URL=postgresql://veltro_user:password@localhost:6432/veltro?pgBouncer=true&connection_limit=1
DIRECT_URL=postgresql://veltro_user:password@localhost:5432/veltro
DB_USER=veltro_user
DB_PASSWORD=strong_password_here

# ── REDIS 8 ───────────────────────────────────────────────────────────
REDIS_URL=redis://:strong_redis_password@localhost:6379
REDIS_PASSWORD=strong_redis_password

# ── GOOGLE OAUTH (GSC + GA4 — shared token) ──────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_REDIRECT_URI=https://veltro.io/api/connectors/google/callback

# ── AHREFS ────────────────────────────────────────────────────────────
AHREFS_API_KEY=your_ahrefs_api_key

# ── BING WEBMASTER TOOLS ─────────────────────────────────────────────
# Customers paste their own key — no platform key needed

# ── PAYMENTS — PAYBRIDGE AFRICA (primary) ────────────────────────────
PAYBRIDGE_API_URL=https://api.paybridgeafrica.com/v1
PAYBRIDGE_API_KEY=your_paybridge_api_key
PAYBRIDGE_SECRET=your_paybridge_secret
PAYBRIDGE_WEBHOOK_SECRET=your_paybridge_webhook_secret

# ── PAYMENTS — STRIPE (fallback EU/CA/US) ────────────────────────────
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── PAYMENTS — ORANGE MONEY ───────────────────────────────────────────
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay/dev/v1
ORANGE_MONEY_MERCHANT_KEY=your_orange_money_key

# ── PAYMENTS — MTN MOMO ───────────────────────────────────────────────
MTN_MOMO_API_URL=https://proxy.momoapi.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=your_mtn_subscription_key
MTN_MOMO_API_USER=your_mtn_api_user
MTN_MOMO_API_KEY=your_mtn_api_key

# ── PAYMENTS — WAVE ───────────────────────────────────────────────────
WAVE_API_KEY=your_wave_api_key

# ── DELIVERY — WHATSAPP (Meta Business API) ──────────────────────────
WHATSAPP_TOKEN=your_whatsapp_business_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id
# Template must be pre-approved by Meta
WHATSAPP_TEMPLATE_EN=veltro_weekly_hunt_en
WHATSAPP_TEMPLATE_FR=veltro_weekly_hunt_fr

# ── DELIVERY — EMAIL (Resend recommended) ────────────────────────────
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=your_resend_api_key
EMAIL_FROM=veltro@yourdomain.com

# ── DELIVERY — SMS ────────────────────────────────────────────────────
SMS_PROVIDER=africastalking        # 'twilio' | 'africastalking'
# Africa's Talking (recommended for Africa)
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=your_at_username
# Twilio (fallback)
TWILIO_SID=your_twilio_sid
TWILIO_TOKEN=your_twilio_token
TWILIO_FROM=+1234567890

# ── CDN UPLOAD (ZIP delivery — never attachments) ────────────────────
CDN_PROVIDER=r2                    # 'r2' | 's3'
# Cloudflare R2 (no egress fees — preferred)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_BUCKET_NAME=veltro-deliveries
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
# AWS S3 (alternative)
S3_BUCKET=veltro-deliveries
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=your_s3_key
S3_SECRET_ACCESS_KEY=your_s3_secret

# ── IMAGE GENERATION ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-...              # DALL-E 3 (optional)

# ── VIDEO PIPELINE (Remotion — free render, no paid API) ─────────────
# Script: Anthropic (Claude). Voice: ElevenLabs. Footage: free stock.
ELEVENLABS_API_KEY=your_elevenlabs_key
PEXELS_API_KEY=your_pexels_key        # free stock video + photos
PIXABAY_API_KEY=your_pixabay_key      # free stock video fallback
UNSPLASH_ACCESS_KEY=your_unsplash_key # free stock images fallback
RENDER_CONCURRENCY=1                   # parallel Remotion renders per worker
CDN_PUBLIC_URL=https://cdn.veltro.io   # public base for rendered MP4s
# Publishing (optional — returns live URLs)
YOUTUBE_API_KEY=your_youtube_key
LINKEDIN_ACCESS_TOKEN=your_linkedin_token
BUFFER_ACCESS_TOKEN=your_buffer_token  # TikTok / Instagram / X scheduling

# ── MONITORING (Bible V2) ─────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=strong_grafana_password
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100

# ── TRAEFIK ───────────────────────────────────────────────────────────
DOMAIN=veltro.io
ACME_EMAIL=admin@veltro.io
TRAEFIK_DASHBOARD_AUTH=admin:hashed_password

# ── KEYCLOAK 24 ───────────────────────────────────────────────────────
KC_ADMIN=admin
KC_ADMIN_PASSWORD=strong_keycloak_password
# ── AI (i18n dynamic translation) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── SEED (db:seed) ────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@veltro.io
SEED_ADMIN_PASSWORD=change-me-now

# ── PUBLIC (frontend) ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://veltro.io
NEXT_PUBLIC_API_URL=https://api.veltro.io

# ── TRIAL ─────────────────────────────────────────────────────────────
TRIAL_DAYS=7                          # free trial length before charge

# ── CENTRAL ENGINE (acquisition discovery + scoring — sovereign) ──────
# The platform NEVER scores locally. Leave empty → discovery returns empty.
CENTRAL_ENGINE_URL=https://engine.internal
CENTRAL_ENGINE_KEY=CHANGE_ME

# ── FREE-TIER COST CONTROL (minimise notre coût en essai) ─────────────
FREE_TRIAL_AI_CALLS=15      # ops IA chères max pendant l'essai
FREE_TRIAL_VIDEOS=0         # vidéos rendues en essai (0 = bloqué, le plus cher)
FREE_TRIAL_HUNTS=1          # hunts manuels max pendant l'essai
